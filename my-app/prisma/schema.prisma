generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  DRAFT
  DISPATCHED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Trip {
  id          String     @id @default(cuid())
  route       String
  vehicle     String?
  driver      String?
  cargoWeight Int        @default(0)
  distanceKm  Int        @default(0)
  status      TripStatus @default(DRAFT)
  time        String?    @default("")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}